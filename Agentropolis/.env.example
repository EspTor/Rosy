# Agentropolis Environment Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://agentropolis:changeme@localhost:5432/agentropolis
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis://:changeme@localhost:6379/0

# Security
JWT_SECRET=generate-with-openssl-rand-base64-32
AGENT_TOKEN_SECRET=generate-with-openssl-rand-base64-32

# API
API_HOST=0.0.0.0
API_PORT=8000

# Simulation
TICKS_PER_SECOND=10
MAX_AGENTS=1000

# LLM (optional)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...

# Logging
LOG_LEVEL=INFO
