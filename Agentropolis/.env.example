1|# Agentropolis Environment Configuration
     2|# Copy to .env and fill in values
     3|
     4|# Database
     5|DATABASE_URL=postgresql://agentropolis:***@localhost:5432/agentropolis
     6|POSTGRES_PASSWORD=***
     7|
     8|# Redis
     9|REDIS_URL=redis://:changeme@localhost:6379/0
    10|
    11|# Security
    12|JWT_SECRET=genera...4-32
    13|AGENT_TOKEN_SECRET=genera...4-32
    14|
    15|# API
    16|API_HOST=0.0.0.0
    17|API_PORT=8000
    18|
    19|# Simulation
    20|TICKS_PER_SECOND=10
    21|MAX_AGENTS=1000
    22|
    23|# LLM (optional)
    24|OPENAI_API_KEY=***
    25|ANTHROPIC_API_KEY=***
    26|
    27|# Logging
    28|LOG_LEVEL=INFO
    29|

# ---- LLM Brain Configuration ----
# OpenRouter free tier model
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_API_KEY=YOUR_OPENROUTER_KEY_HERE
LLM_MODEL=meta-llama/llama-3.2-3b-instruct
LLM_DECISION_COOLDOWN_TICKS=100
LLM_ACTION_COOLDOWN_TICKS=20
LLM_REQUEST_TIMEOUT=15