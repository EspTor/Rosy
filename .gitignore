# Obsidian specific files
.obsidian/
# This folder contains vault-specific settings, plugins, and themes.
# You might want to sync it if you want consistent settings across devices.
# Consider whether you want to include plugin data (can be large).

# Temporary files
*.tmp
*.temp
.DS_Store
Thumbs.db

